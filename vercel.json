{
  "rewrites": [
    {
      "source": "/bluecore-api/:match*",
      "destination": "https://admin-apis.bluecore.vn/:match*"
    },
    {
      "source": "/tiktok-shop/callback",
      "destination": "/api/tiktok-shop/callback"
    }
  ],
  "functions": {
    "api/tiktok-shop/sync-orders.js": {
      "maxDuration": 800
    }
  },
  "crons": [
    {
      "path": "/api/tiktok-shop/sync-orders",
      "schedule": "0 21 * * *"
    }
  ]
}
